{
  "openapi": "3.0.0",
  "info": {
    "title": "MyLifeApp API",
    "description": "个人成长养成游戏 API",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "本地开发环境"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT 认证，从 login 接口获取 token"
      }
    },
    "schemas": {
      "Result": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码，200表示成功"
          },
          "message": {
            "type": "string",
            "description": "消息"
          },
          "data": {
            "description": "数据"
          }
        }
      },
      "Result_TokenVO": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "登录成功"
          },
          "data": {
            "$ref": "#/components/schemas/TokenVO"
          }
        }
      },
      "Result_UserVO": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "注册成功"
          },
          "data": {
            "$ref": "#/components/schemas/UserVO"
          }
        }
      },
      "Result_Task": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "创建成功"
          },
          "data": {
            "$ref": "#/components/schemas/Task"
          }
        }
      },
      "Result_Void": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "操作成功"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "UserLoginDTO": {
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "用户名",
            "maxLength": 50
          },
          "password": {
            "type": "string",
            "description": "密码",
            "maxLength": 100
          }
        },
        "example": {
          "username": "testuser",
          "password": "123456"
        }
      },
      "UserRegisterDTO": {
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "用户名",
            "maxLength": 50
          },
          "password": {
            "type": "string",
            "description": "密码",
            "maxLength": 100
          }
        },
        "example": {
          "username": "testuser",
          "password": "123456"
        }
      },
      "TokenVO": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT Token"
          }
        },
        "example": {
          "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
        }
      },
      "UserVO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "用户ID"
          },
          "username": {
            "type": "string",
            "description": "用户名"
          },
          "level": {
            "type": "integer",
            "description": "等级"
          },
          "exp": {
            "type": "integer",
            "description": "经验值"
          },
          "coin": {
            "type": "integer",
            "description": "金币"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "用户ID"
          },
          "username": {
            "type": "string",
            "description": "用户名"
          },
          "level": {
            "type": "integer",
            "description": "等级"
          },
          "exp": {
            "type": "integer",
            "description": "经验值"
          },
          "coin": {
            "type": "integer",
            "description": "金币"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "任务ID"
          },
          "title": {
            "type": "string",
            "description": "任务标题"
          },
          "description": {
            "type": "string",
            "description": "任务描述"
          },
          "expReward": {
            "type": "integer",
            "description": "经验奖励"
          },
          "coinReward": {
            "type": "integer",
            "description": "金币奖励"
          },
          "category": {
            "type": "string",
            "description": "任务分类"
          },
          "priority": {
            "type": "integer",
            "description": "优先级"
          },
          "dueDate": {
            "type": "string",
            "format": "date-time",
            "description": "截止日期"
          },
          "status": {
            "type": "string",
            "description": "任务状态"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TaskCreateDTO": {
        "type": "object",
        "required": [
          "title",
          "expReward",
          "coinReward"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "任务标题",
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "description": "任务描述",
            "maxLength": 500
          },
          "expReward": {
            "type": "integer",
            "description": "经验奖励",
            "minimum": 1
          },
          "coinReward": {
            "type": "integer",
            "description": "金币奖励",
            "minimum": 1
          },
          "category": {
            "type": "string",
            "description": "任务分类"
          },
          "priority": {
            "type": "integer",
            "description": "优先级"
          },
          "dueDate": {
            "type": "string",
            "format": "date-time",
            "description": "截止日期"
          }
        },
        "example": {
          "title": "完成 LeetCode",
          "description": "每天刷 2 道题",
          "expReward": 20,
          "coinReward": 10,
          "category": "study",
          "priority": 3
        }
      },
      "TaskUpdateDTO": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "maxLength": 500
          },
          "category": {
            "type": "string"
          },
          "priority": {
            "type": "integer"
          },
          "dueDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "integer",
            "description": "1:收入, 2:支出"
          },
          "icon": {
            "type": "string"
          },
          "color": {
            "type": "string"
          }
        }
      },
      "TransactionVO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "type": {
            "type": "integer",
            "description": "1:收入, 2:支出"
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "note": {
            "type": "string"
          },
          "transactionDate": {
            "type": "string",
            "format": "date"
          },
          "categoryId": {
            "type": "integer"
          },
          "categoryName": {
            "type": "string"
          }
        }
      },
      "TransactionCreateDTO": {
        "type": "object",
        "required": [
          "type",
          "amount",
          "categoryId",
          "transactionDate"
        ],
        "properties": {
          "type": {
            "type": "integer",
            "description": "1:收入, 2:支出"
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "categoryId": {
            "type": "integer"
          },
          "note": {
            "type": "string"
          },
          "transactionDate": {
            "type": "string",
            "format": "date"
          }
        },
        "example": {
          "type": 2,
          "amount": 12.5,
          "categoryId": 1,
          "note": "午餐",
          "transactionDate": "2026-03-21"
        }
      },
      "WishlistVO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "targetAmount": {
            "type": "number",
            "format": "double"
          },
          "currentAmount": {
            "type": "number",
            "format": "double"
          },
          "progress": {
            "type": "integer"
          },
          "remaining": {
            "type": "number",
            "format": "double"
          },
          "priority": {
            "type": "integer"
          },
          "status": {
            "type": "integer"
          },
          "targetDate": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "WishlistCreateDTO": {
        "type": "object",
        "required": [
          "title",
          "targetAmount"
        ],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "maxLength": 500
          },
          "targetAmount": {
            "type": "number",
            "format": "double"
          },
          "priority": {
            "type": "integer"
          },
          "targetDate": {
            "type": "string",
            "format": "date"
          }
        },
        "example": {
          "title": "Switch 游戏机",
          "description": "任天堂 Switch",
          "targetAmount": 1999.0,
          "priority": 1,
          "targetDate": "2026-12-31"
        }
      },
      "DepositDTO": {
        "type": "object",
        "required": [
          "wishlistId",
          "amount"
        ],
        "properties": {
          "wishlistId": {
            "type": "integer"
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "note": {
            "type": "string"
          }
        },
        "example": {
          "wishlistId": 1,
          "amount": 100.0,
          "note": "本周存钱"
        }
      }
    }
  },
  "paths": {
    "/api/user/register": {
      "post": {
        "summary": "用户注册",
        "tags": [
          "用户管理"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserRegisterDTO"
              },
              "example": {
                "username": "testuser",
                "password": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "注册成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result_UserVO"
                },
                "example": {
                  "code": 200,
                  "message": "注册成功",
                  "data": {
                    "id": 1,
                    "username": "testuser",
                    "level": 1,
                    "exp": 0,
                    "coin": 0
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/user/login": {
      "post": {
        "summary": "用户登录",
        "tags": [
          "用户管理"
        ],
        "requestBody": {
          "required": true,
          "description": "用户名和密码",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserLoginDTO"
              },
              "example": {
                "username": "testuser",
                "password": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功，返回 JWT Token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result_TokenVO"
                },
                "example": {
                  "code": 200,
                  "message": "登录成功",
                  "data": {
                    "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/user/info": {
      "get": {
        "summary": "获取用户信息",
        "tags": [
          "用户管理"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          }
        }
      }
    },
    "/api/task/list": {
      "get": {
        "summary": "获取任务列表",
        "tags": [
          "任务管理"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Task"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/task/create": {
      "post": {
        "summary": "创建任务",
        "tags": [
          "任务管理"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskCreateDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result_Task"
                }
              }
            }
          }
        }
      }
    },
    "/api/task/update/{id}": {
      "put": {
        "summary": "更新任务",
        "tags": [
          "任务管理"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskUpdateDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result_Task"
                }
              }
            }
          }
        }
      }
    },
    "/api/task/delete/{id}": {
      "delete": {
        "summary": "删除任务",
        "tags": [
          "任务管理"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "删除成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result_Void"
                }
              }
            }
          }
        }
      }
    },
    "/api/task/complete/{id}": {
      "post": {
        "summary": "完成任务",
        "tags": [
          "任务管理"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "操作成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result_Void"
                }
              }
            }
          }
        }
      }
    },
    "/category/list": {
      "get": {
        "summary": "获取分类列表",
        "tags": [
          "分类管理"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "enum": [
                1,
                2
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Category"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/transaction/list": {
      "get": {
        "summary": "获取交易列表",
        "tags": [
          "记账功能"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TransactionVO"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/transaction/add": {
      "post": {
        "summary": "记一笔",
        "tags": [
          "记账功能"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransactionCreateDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "记账成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result_Void"
                }
              }
            }
          }
        }
      }
    },
    "/wishlist/list": {
      "get": {
        "summary": "获取心愿列表",
        "tags": [
          "心愿单"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result"
                }
              }
            }
          }
        }
      }
    },
    "/wishlist/create": {
      "post": {
        "summary": "创建心愿",
        "tags": [
          "心愿单"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WishlistCreateDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result_Void"
                }
              }
            }
          }
        }
      }
    },
    "/wishlist/deposit": {
      "post": {
        "summary": "存入金币",
        "tags": [
          "心愿单"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DepositDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "存钱成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result_Void"
                }
              }
            }
          }
        }
      }
    }
  }
}