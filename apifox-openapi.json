{
  "openapi": "3.0.0",
  "info": {
    "title": "MyLifeApp API",
    "description": "个人成长养成游戏 API 文档\n\n## 功能说明\n- **JWT 认证**：基于 Bearer Token 的用户认证\n- **任务管理**：创建、完成、删除任务，支持分类、优先级、截止日期\n- **记账功能**：记录收入/支出，支持分类管理\n- **心愿单**：设定心愿目标、存钱进度跟踪、购买打卡\n\n## 认证说明\n除了 `/api/user/register` 和 `/api/user/login` 外，所有接口都需要在 Header 中携带 JWT Token：\n```\nAuthorization: Bearer {your_jwt_token}\n```\n\nJWT Token 从登录接口的 `data.token` 字段获取。",
    "version": "2.0.0",
    "contact": {
      "name": "MyLifeApp Team"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "本地开发环境"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT Token 认证。从 `/api/user/login` 接口获取 Token，然后在 Header 中添加：`Authorization: Bearer {token}`"
      }
    },
    "schemas": {
      "Result": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "响应状态码，200 表示成功"
          },
          "message": {
            "type": "string",
            "description": "响应消息"
          },
          "data": {
            "description": "响应数据"
          }
        }
      },
      "UserLoginDTO": {
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "用户名",
            "maxLength": 50
          },
          "password": {
            "type": "string",
            "description": "密码",
            "maxLength": 100
          }
        }
      },
      "UserRegisterDTO": {
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "username": {
            "type": "string",
            "description": "用户名",
            "maxLength": 50
          },
          "password": {
            "type": "string",
            "description": "密码",
            "maxLength": 100
          }
        }
      },
      "TokenVO": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT Token，用于后续接口认证"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "用户ID"
          },
          "username": {
            "type": "string",
            "description": "用户名"
          },
          "level": {
            "type": "integer",
            "description": "等级"
          },
          "exp": {
            "type": "integer",
            "description": "经验值"
          },
          "coin": {
            "type": "integer",
            "description": "金币"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "任务ID"
          },
          "title": {
            "type": "string",
            "description": "任务标题"
          },
          "description": {
            "type": "string",
            "description": "任务描述"
          },
          "expReward": {
            "type": "integer",
            "description": "经验奖励"
          },
          "coinReward": {
            "type": "integer",
            "description": "金币奖励"
          },
          "category": {
            "type": "string",
            "description": "任务分类",
            "enum": [
              "general",
              "study",
              "work",
              "life",
              "health"
            ]
          },
          "priority": {
            "type": "integer",
            "description": "优先级 (1:低, 2:中, 3:高)"
          },
          "dueDate": {
            "type": "string",
            "format": "date-time",
            "description": "截止日期"
          },
          "status": {
            "type": "string",
            "description": "任务状态",
            "enum": [
              "pending",
              "in_progress",
              "done"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TaskCreateDTO": {
        "type": "object",
        "required": [
          "title",
          "expReward",
          "coinReward"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "任务标题",
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "description": "任务描述",
            "maxLength": 500
          },
          "expReward": {
            "type": "integer",
            "description": "经验奖励",
            "minimum": 1,
            "maximum": 10000
          },
          "coinReward": {
            "type": "integer",
            "description": "金币奖励",
            "minimum": 1,
            "maximum": 10000
          },
          "category": {
            "type": "string",
            "description": "任务分类",
            "enum": [
              "general",
              "study",
              "work",
              "life",
              "health"
            ],
            "default": "general"
          },
          "priority": {
            "type": "integer",
            "description": "优先级",
            "minimum": 1,
            "maximum": 3,
            "default": 2
          },
          "dueDate": {
            "type": "string",
            "format": "date-time",
            "description": "截止日期"
          }
        }
      },
      "TaskUpdateDTO": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "maxLength": 500
          },
          "category": {
            "type": "string",
            "enum": [
              "general",
              "study",
              "work",
              "life",
              "health"
            ]
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3
          },
          "dueDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "分类ID"
          },
          "name": {
            "type": "string",
            "description": "分类名称"
          },
          "type": {
            "type": "integer",
            "description": "分类类型 (1:收入, 2:支出)"
          },
          "icon": {
            "type": "string",
            "description": "图标名称"
          },
          "color": {
            "type": "string",
            "description": "颜色"
          },
          "sortOrder": {
            "type": "integer",
            "description": "排序"
          }
        }
      },
      "TransactionVO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "交易ID"
          },
          "type": {
            "type": "integer",
            "description": "类型 (1:收入, 2:支出)"
          },
          "amount": {
            "type": "number",
            "format": "double",
            "description": "金额"
          },
          "note": {
            "type": "string",
            "description": "备注"
          },
          "transactionDate": {
            "type": "string",
            "format": "date",
            "description": "交易日期"
          },
          "categoryId": {
            "type": "integer",
            "description": "分类ID"
          },
          "categoryName": {
            "type": "string",
            "description": "分类名称"
          }
        }
      },
      "TransactionCreateDTO": {
        "type": "object",
        "required": [
          "type",
          "amount",
          "categoryId",
          "transactionDate"
        ],
        "properties": {
          "type": {
            "type": "integer",
            "description": "类型 (1:收入, 2:支出)"
          },
          "amount": {
            "type": "number",
            "format": "double",
            "description": "金额",
            "minimum": 0.01
          },
          "categoryId": {
            "type": "integer",
            "description": "分类ID"
          },
          "note": {
            "type": "string",
            "description": "备注",
            "maxLength": 200
          },
          "transactionDate": {
            "type": "string",
            "format": "date",
            "description": "交易日期"
          }
        }
      },
      "WishlistVO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "心愿ID"
          },
          "title": {
            "type": "string",
            "description": "心愿标题"
          },
          "description": {
            "type": "string",
            "description": "心愿描述"
          },
          "targetAmount": {
            "type": "number",
            "format": "double",
            "description": "目标金额"
          },
          "currentAmount": {
            "type": "number",
            "format": "double",
            "description": "当前金额"
          },
          "progress": {
            "type": "integer",
            "description": "进度百分比 (0-100)"
          },
          "remaining": {
            "type": "number",
            "format": "double",
            "description": "还需金额"
          },
          "priority": {
            "type": "integer",
            "description": "优先级 (1:高, 2:中, 3:低)"
          },
          "status": {
            "type": "integer",
            "description": "状态 (0:进行中, 1:已实现, 2:已放弃)"
          },
          "targetDate": {
            "type": "string",
            "format": "date",
            "description": "目标日期"
          }
        }
      },
      "WishlistCreateDTO": {
        "type": "object",
        "required": [
          "title",
          "targetAmount"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "心愿标题",
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "description": "心愿描述",
            "maxLength": 500
          },
          "targetAmount": {
            "type": "number",
            "format": "double",
            "description": "目标金额",
            "minimum": 0.01
          },
          "priority": {
            "type": "integer",
            "description": "优先级 (1:高, 2:中, 3:低)",
            "minimum": 1,
            "maximum": 3,
            "default": 2
          },
          "targetDate": {
            "type": "string",
            "format": "date",
            "description": "目标日期"
          }
        }
      },
      "DepositDTO": {
        "type": "object",
        "required": [
          "wishlistId",
          "amount"
        ],
        "properties": {
          "wishlistId": {
            "type": "integer",
            "description": "心愿ID"
          },
          "amount": {
            "type": "number",
            "format": "double",
            "description": "存入金额",
            "minimum": 0.01
          },
          "note": {
            "type": "string",
            "description": "备注"
          }
        }
      }
    }
  },
  "paths": {
    "/api/user/register": {
      "post": {
        "summary": "用户注册",
        "tags": [
          "用户管理"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserRegisterDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "注册成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result"
                }
              }
            }
          }
        }
      }
    },
    "/api/user/login": {
      "post": {
        "summary": "用户登录",
        "tags": [
          "用户管理"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserLoginDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result"
                }
              }
            }
          }
        }
      }
    },
    "/api/user/info": {
      "get": {
        "summary": "获取用户信息",
        "tags": [
          "用户管理"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          }
        }
      }
    },
    "/api/task/list": {
      "get": {
        "summary": "获取任务列表",
        "tags": [
          "任务管理"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Task"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/task/create": {
      "post": {
        "summary": "创建任务",
        "tags": [
          "任务管理"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskCreateDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result"
                }
              }
            }
          }
        }
      }
    },
    "/api/task/update/{id}": {
      "put": {
        "summary": "更新任务",
        "tags": [
          "任务管理"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TaskUpdateDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result"
                }
              }
            }
          }
        }
      }
    },
    "/api/task/delete/{id}": {
      "delete": {
        "summary": "删除任务",
        "tags": [
          "任务管理"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "删除成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result"
                }
              }
            }
          }
        }
      }
    },
    "/api/task/complete/{id}": {
      "post": {
        "summary": "完成任务",
        "tags": [
          "任务管理"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "操作成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result"
                }
              }
            }
          }
        }
      }
    },
    "/category/list": {
      "get": {
        "summary": "获取分类列表",
        "tags": [
          "分类管理"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "enum": [
                1,
                2
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Category"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/transaction/list": {
      "get": {
        "summary": "获取交易列表",
        "tags": [
          "记账功能"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TransactionVO"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/transaction/add": {
      "post": {
        "summary": "记一笔",
        "tags": [
          "记账功能"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransactionCreateDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "记账成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result"
                }
              }
            }
          }
        }
      }
    },
    "/wishlist/list": {
      "get": {
        "summary": "获取心愿列表",
        "tags": [
          "心愿单"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result"
                }
              }
            }
          }
        }
      }
    },
    "/wishlist/create": {
      "post": {
        "summary": "创建心愿",
        "tags": [
          "心愿单"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WishlistCreateDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result"
                }
              }
            }
          }
        }
      }
    },
    "/wishlist/deposit": {
      "post": {
        "summary": "存入金币",
        "tags": [
          "心愿单"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DepositDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "存钱成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Result"
                }
              }
            }
          }
        }
      }
    }
  }
}